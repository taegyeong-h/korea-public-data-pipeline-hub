import requests
import time

AUTH_KEY="7656714c4567757336356769446c6b"
url = f'http://openapi.seoul.go.kr:8088/{AUTH_KEY}/json/bikeList/1/1000/'

try:
    response = requests.get(url, timeout=10)

    if response.status_code == 200:
        res_json = response.json()
        total = res_json.get("rentBikeStatus")
        res_rows = total.get("row")
        time.sleep(0.1)

    else:
        print(f"API 요청에 실패했습니다. 상태코드: {response.status_code}")
except Exception as e:
    print(f"💥 파이프라인 통신 중 치명적 에러 발생: {e}")


import polars as pl

df = pl.DataFrame(res_rows)
print(df)

target_duplicates = df.filter(
    pl.struct(["stationId"]).is_duplicated()
)
print(target_duplicates)



print(df.schema)
print(df.glimpse())


df_clean = df.select([
    # 변경하지 않을 문자열 컬럼들 유지
    pl.col("stationName"),
    pl.col("stationId"),
    
    # 숫자형으로 변환할 컬럼들 지정 (Int64 또는 Int32, Float64 등)
    pl.col(["rackTotCnt", "parkingBikeTotCnt", "shared"]).cast(pl.Int64),
    
    # 위도/경도는 소수점이 있으므로 실수형(Float64)으로 변환
    pl.col(["stationLatitude", "stationLongitude"]).cast(pl.Float64)
])

print(df_clean)
